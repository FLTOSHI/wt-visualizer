<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>prs.fltoshi</groupId>
    <artifactId>wt-visualizer</artifactId>
    <version>1.0-SNAPSHOT</version>

    <properties>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <javafx.version>21.0.2</javafx.version>
        <ikonli.version>12.3.1</ikonli.version>
    </properties>

    <dependencies>
        <!-- JavaFX -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-controls</artifactId>
            <version>${javafx.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-fxml</artifactId>
            <version>${javafx.version}</version>
        </dependency>

        <!-- UI Libraries -->
        <dependency>
            <groupId>eu.hansolo</groupId>
            <artifactId>tilesfx</artifactId>
            <version>21.0.3</version>
        </dependency>
        <dependency>
            <groupId>org.kordamp.ikonli</groupId>
            <artifactId>ikonli-javafx</artifactId>
            <version>${ikonli.version}</version>
        </dependency>
        <dependency>
            <groupId>org.kordamp.ikonli</groupId>
            <artifactId>ikonli-fontawesome5-pack</artifactId>
            <version>${ikonli.version}</version>
        </dependency>
        <dependency>
            <groupId>org.controlsfx</groupId>
            <artifactId>controlsfx</artifactId>
            <version>11.2.1</version>
        </dependency>

        <!-- Core Dependencies -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <version>1.18.30</version>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>2.17.0</version>
        </dependency>
        <dependency>
            <groupId>org.jooq</groupId>
            <artifactId>jooq</artifactId>
            <version>3.19.5</version>
        </dependency>

        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <version>42.7.2</version>
        </dependency>
        <dependency>
            <groupId>com.zaxxer</groupId>
            <artifactId>HikariCP</artifactId>
            <version>5.1.0</version>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.jooq</groupId>
                <artifactId>jooq-codegen-maven</artifactId>
                <version>3.19.5</version>
                <executions>
                    <execution>
                        <id>jooq-codegen</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                    </execution>
                </executions>

                <dependencies>
                    <dependency>
                        <groupId>org.postgresql</groupId>
                        <artifactId>postgresql</artifactId>
                        <version>42.7.2</version>
                    </dependency>
                </dependencies>

                <configuration>
                    <jdbc>
                        <driver>org.postgresql.Driver</driver>
                        <url>jdbc:postgresql://localhost:5432/wt_db</url>
                        <user>postgres</user>
                        <password>root</password>
                    </jdbc>
                    <generator>
                        <database>
                            <name>org.jooq.meta.postgres.PostgresDatabase</name>
                            <includes>.*</includes>
                            <inputSchema>public</inputSchema>
                            
                            <forcedTypes>
                                <forcedType>
                                    <userType>prs.fltoshi.models.common.WeaponSystem</userType>
                                    <converter>new prs.fltoshi.db.converters.JsonbConverter(prs.fltoshi.models.common.WeaponSystem.class)</converter>
                                    <includeExpression>weapon_system</includeExpression>
                                </forcedType>
                                <forcedType>
                                    <userType>prs.fltoshi.models.common.EngineStats</userType>
                                    <converter>new prs.fltoshi.db.converters.JsonbConverter(prs.fltoshi.models.common.EngineStats.class)</converter>
                                    <includeExpression>engine_data</includeExpression>
                                </forcedType>
                                <forcedType>
                                    <userType>prs.fltoshi.models.common.EconomyRewards</userType>
                                    <converter>new prs.fltoshi.db.converters.JsonbConverter(prs.fltoshi.models.common.EconomyRewards.class)</converter>
                                    <includeExpression>economy_data</includeExpression>
                                </forcedType>
                                <forcedType>
                                    <userType>prs.fltoshi.models.common.CrewService</userType>
                                    <converter>new prs.fltoshi.db.converters.JsonbConverter(prs.fltoshi.models.common.CrewService.class)</converter>
                                    <includeExpression>crew_data</includeExpression>
                                </forcedType>
                                <forcedType>
                                    <userType>prs.fltoshi.models.common.SensorSuite</userType>
                                    <converter>new prs.fltoshi.db.converters.JsonbConverter(prs.fltoshi.models.common.SensorSuite.class)</converter>
                                    <includeExpression>sensors_data</includeExpression>
                                </forcedType>
                                <forcedType>
                                    <userType>prs.fltoshi.models.common.Modification[]</userType>
                                    <converter>new prs.fltoshi.db.converters.JsonbConverter(prs.fltoshi.models.common.Modification[].class)</converter>
                                    <includeExpression>modifications</includeExpression>
                                </forcedType>
                            </forcedTypes>
                        </database>
                        <target>
                            <packageName>prs.fltoshi.db.generated</packageName>
                            <directory>${project.build.directory}/generated-sources/jooq</directory>
                        </target>
                    </generator>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>build-helper-maven-plugin</artifactId>
                <version>3.5.0</version>
                <executions>
                    <execution>
                        <id>add-source</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>add-source</goal>
                        </goals>
                        <configuration>
                            <sources>
                                <source>${project.build.directory}/generated-sources/jooq</source>
                            </sources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>